# Kuberna Labs Frontend Environment Variables
# ============================================
# Copy this file to .env.local for local development
# On Render, prefix with NEXT_PUBLIC_ and set via Render dashboard
#
# The frontend uses relative API URLs (/api/...) so no API URL config
# is needed for production (same origin). Set NEXT_PUBLIC_API_URL
# only for local dev when backend runs on a different port.

# API Base URL (Optional - defaults to same origin)
# Local dev: NEXT_PUBLIC_API_URL=http://localhost:3000
# Production: not needed (uses relative URLs)
NEXT_PUBLIC_API_URL=http://localhost:3000

# WalletConnect Project ID (Required for wallet connections)
# Get one free at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# App Name (Optional)
NEXT_PUBLIC_APP_NAME=Kuberna Labs

# Blockchain RPC URLs (Optional - uses public RPCs by default)
NEXT_PUBLIC_ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_key
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_key
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/your_key
NEXT_PUBLIC_NEAR_RPC_URL=https://rpc.mainnet.near.org

# Analytics (Optional)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Smart Contract Addresses (Base Sepolia)
# Override these with NEXT_PUBLIC_ prefix in production
NEXT_PUBLIC_ESCROW_CONTRACT_ADDRESS=0x360ec009ba6967F5f7C53a88FAD0452C6140493d
