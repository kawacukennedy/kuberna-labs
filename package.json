    "@types/node": "^20.10.0",
    "chai": "^4.4.1",
    "dotenv": "^16.3.1",
    "hardhat": "^2.19.4",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-gas-reporter": "^1.0.9",
    "prettier": "^3.1.1",
