{
  "name": "kuberna-labs",
  "version": "0.1.0",
  "description": "Decentralized platform connecting AI agents with educational opportunities and work tasks using blockchain and TEE technology",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/kawacukennedy/kuberna-labs.git"
  },
  "bugs": {
    "url": "https://github.com/kawacukennedy/kuberna-labs/issues"
  },
  "homepage": "https://github.com/kawacukennedy/kuberna-labs#readme",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network mainnet",
    "deploy:polygon": "hardhat run scripts/deploy.ts --network polygon",
    "deploy:arbitrum": "hardhat run scripts/deploy.ts --network arbitrum",
    "verify": "hardhat run scripts/verify.ts",
    "setup:local": "hardhat run scripts/setup-local.ts --network localhost",
    "verify:setup": "ts-node scripts/verify-setup.ts",
    "node": "hardhat node",
    "clean": "hardhat clean",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,sol,json,md}\"",
    "dev": "cd frontend && npm run dev",
    "install:frontend": "cd frontend && npm install"
  },
  "keywords": [
    "web3",
    "blockchain",
    "ai-agents",
    "education",
    "smart-contracts",
    "defi",
    "tee",
    "trusted-execution-environment",
    "ethereum",
    "polygon",
    "base",
    "nft",
    "certificates",
    "decentralized",
    "marketplace"
  ],
  "author": {
    "name": "Kennedy Kawacuk",
    "email": "kennedy@kubernalabs.com",
    "url": "https://github.com/kawacukennedy"
  },
  "contributors": [
    {
      "name": "Kennedy Kawacuk",
      "email": "kennedy@kubernalabs.com",
      "url": "https://github.com/kawacukennedy"
    }
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "chai": "^4.4.1",
    "dotenv": "^16.3.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "ethers": "^6.16.0",
    "fast-check": "^4.6.0",
    "hardhat": "^2.19.4",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-gas-reporter": "^1.0.9",
    "prettier": "^3.1.1",
    "prettier-plugin-solidity": "^1.3.1",
    "solhint": "^4.1.1",
    "solidity-coverage": "^0.8.5",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.4.0",
    "@openzeppelin/contracts": "^5.0.2",
    "@tanstack/react-query": "^5.17.0",
    "viem": "^2.0.0",
    "wagmi": "^2.0.0"
  }
}
