# Kuberna Labs Backend Environment Variables
# ==========================================
# Copy this file to .env for local development
# On Render, set these via Environment Variables in the dashboard
#
# REQUIRED for production:
#   DATABASE_URL, JWT_SECRET
#
# REQUIRED for blockchain features:
#   PRIVATE_KEY, RPC_URL, contract addresses
#
# OPTIONAL: all other variables

# --- Database (Required) ---
# For local dev: postgresql://user:password@localhost:5432/kuberna
# For Supabase (runtime via transaction pooler):
#   DATABASE_URL="postgresql://postgres.project-ref:password@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#   DIRECT_URL="postgresql://postgres.project-ref:password@aws-1-eu-north-1.pooler.supabase.com:5432/postgres"
# For Render: Use Render Managed PostgreSQL or external (Neon/Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/kuberna

# --- Server ---
PORT=3000
NODE_ENV=development

# --- JWT (Required) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-min-16-chars
# Optional: if not set, derived from JWT_SECRET
JWT_REFRESH_SECRET=

# --- CORS ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Blockchain (Required for on-chain features) ---
# RPC URL for the chain your contracts are deployed on
RPC_URL=https://sepolia.base.org
# Use `cast wallet` or a hardware wallet for deployments. The backend should use a dedicated, low-balance deployer wallet.
# PRIVATE_KEY is set via environment variables in production — NEVER hardcode it.

# Smart Contract Addresses (Base Sepolia - update if re-deployed)
# See deployments/*-latest.json for all chains
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# All 18 Contract Addresses (Base Sepolia)
ESCROW_CONTRACT_ADDRESS=0xab28501BC5736f56D1Fd909ffD8EB98407EB049E
INTENT_CONTRACT_ADDRESS=0xF9c36107F943C9eECAa88B20C05Bd090322fC56f
CERTIFICATE_NFT_CONTRACT_ADDRESS=0x6CBeE1F98DBd05d5B05A18062B5029c5618D340F
PAYMENT_CONTRACT_ADDRESS=0xc0679cdB6E30291De974635cBaFa572e083e6564
SUBSCRIPTION_CONTRACT_ADDRESS=0x32b0298eF0e0e438A45965Ed26d9EfA2A7Cf9061
REPUTATION_NFT_CONTRACT_ADDRESS=0x10aC2c7cAA2d7C5fC8a561F8654d289eeb2E29F4
AGENT_REGISTRY_CONTRACT_ADDRESS=0x563193BeD72b2b1F284EE0e80b29dADc4D9bEC91
COURSE_NFT_CONTRACT_ADDRESS=0x2b80B538cCC8846AFb3c6cb901A819178c2E805f
WORKSHOP_CONTRACT_ADDRESS=0xe48844e98A6760cd561f025aeD575f44DF5aABa3
DISPUTE_CONTRACT_ADDRESS=0x9d5A959CA6C6c6D1304beBF293387c4208163071
TREASURY_CONTRACT_ADDRESS=0xA5BDFFfA521C2234F74Dd03B1529797068C8A717
FEE_MANAGER_CONTRACT_ADDRESS=0x039C4456CB9C195C2dFD1F370a4891b0857F4aa0
ATTESTATION_CONTRACT_ADDRESS=0x68d0a647E4a1F68CbDA62Ce31273D1d0298C1a02
CROSSCHAIN_ROUTER_CONTRACT_ADDRESS=0xf13Efb8885F11B6E81dE47DF74CC1849a5855edb

# Placeholder Contracts (not yet deployed - set to zero address)
GOVERNANCE_TOKEN_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
PRICE_ORACLE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
MULTISIG_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VESTING_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# --- AI Parser Configuration (All local, no external API keys needed) ---
AI_PARSER_RULE_SET=default
AI_PARSER_MIN_CONFIDENCE=0.6

# --- Agent Decision Engine Configuration ---
AGENT_ARBITRAGE_THRESHOLD=0.5
AGENT_MAX_SLIPPAGE=1.0
AGENT_STOP_LOSS_PERCENT=5.0
AGENT_MIN_YIELD_DIFF=1.0

# --- External Services (Optional) ---
STRIPE_SECRET_KEY=sk_test_xxx
OPENAI_API_KEY=sk-xxx

# --- Redis (Optional - rate limiting falls back gracefully) ---
REDIS_URL=redis://localhost:6379

# --- Email (Optional) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
FROM_EMAIL=noreply@kuberna.africa

# --- Blockchain Listener (Optional - separate process) ---
# Base / Base Sepolia
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_WS_RPC_URL=wss://sepolia.base.org

# Sepolia
SEPOLIA_RPC_URL=https://rpc.sepolia.org
SEPOLIA_WS_RPC_URL=wss://rpc.sepolia.org

# Polygon
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_WS_RPC_URL=wss://polygon-rpc.com

# Arbitrum
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_WS_RPC_URL=wss://arb1.arbitrum.io/ws

# 0G Galileo Testnet
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_WS_RPC_URL=wss://evmrpc-testnet.0g.ai

# Per-chain contract overrides (prefix with CHAINNAME_)
# Example: SEPOLIA_ESCROW_CONTRACT, POLYGON_ESCROW_CONTRACT, ARBITRUM_ESCROW_CONTRACT, OG_ESCROW_CONTRACT
# Falls back to base contract vars (ESCROW_CONTRACT_ADDRESS, etc.)

# Blockchain Listener Settings
POLL_INTERVAL=60000
REQUIRED_CONFIRMATIONS=3
NATS_URL=nats://localhost:4222
