# Database
DATABASE_URL=postgresql://user:password@localhost:5432/kuberna

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Blockchain
RPC_URL=http://localhost:8545
