INTENT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
AGENT_REGISTRY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
CERTIFICATE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
