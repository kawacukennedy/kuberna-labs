# Wallet Private Key (DO NOT COMMIT - use for deployments only)
PRIVATE_KEY=0x...

# ----- Supabase / PostgreSQL (Transaction Pooler — recommended) -----
# Uses PgBouncer transaction pooler for serverless/stateless apps.
# Supports IPv4 (Render, Vercel, Railway, etc.)
DATABASE_URL="postgresql://postgres.rjlnyyqanqhvikhjfmvk:REDACTED@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (bypasses transaction pooler) — used by Prisma Migrate only.
DIRECT_URL="postgresql://postgres.rjlnyyqanqhvikhjfmvk:REDACTED@aws-1-eu-north-1.pooler.supabase.com:5432/postgres"

# ----- Session pooler (fallback for long-lived connections) -----
# Only use this if the transaction pooler causes issues.
# DATABASE_URL="postgresql://postgres.rjlnyyqanqhvikhjfmvk:REDACTED@aws-1-eu-north-1.pooler.supabase.com:5432/postgres"

# ----- JWT Authentication -----
JWT_SECRET="change-me-to-a-random-64-char-string"
JWT_REFRESH_SECRET="change-me-to-another-random-64-char-string"
JWT_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ----- NATS (Message Queue) -----
NATS_URL="nats://localhost:4222"

# ----- Server -----
NODE_ENV="development"
PORT=3000
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# ----- Redis (Rate Limiting / Caching) -----
REDIS_URL="redis://localhost:6379"

# ----- Blockchain -----
PRIVATE_KEY="your-wallet-private-key"
SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/your-infura-key"
REPORT_GAS=true

# Backend Environment Variables
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/kuberna
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# NATS Configuration
NATS_URL=nats://localhost:4222

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email Configuration (SendGrid or AWS SES)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your_sendgrid_key
EMAIL_FROM=noreply@kuberna.africa

# TEE Provider Configuration
PHALA_ENDPOINT=https://api.phala.network
PHALA_API_KEY=your_phala_key
MARLIN_ENDPOINT=https://api.marlin.org
MARLIN_API_KEY=your_marlin_key

# zkTLS Provider Configuration
RECLAIM_API_KEY=your_reclaim_key
ZKPASS_API_KEY=your_zkpass_key

# Contract Addresses (update after deployment)
ESCROW_CONTRACT_ADDRESS_ETHEREUM=
ESCROW_CONTRACT_ADDRESS_POLYGON=
ESCROW_CONTRACT_ADDRESS_ARBITRUM=
INTENT_CONTRACT_ADDRESS_ETHEREUM=
PAYMENT_CONTRACT_ADDRESS_POLYGON=
CERTIFICATE_NFT_ADDRESS_ETHEREUM=
ATTESTATION_CONTRACT_ADDRESS_ETHEREUM=
REPUTATION_NFT_ADDRESS_ETHEREUM=
SUBSCRIPTION_CONTRACT_ADDRESS_ETHEREUM=
CROSSCHAIN_ROUTER_ADDRESS_ETHEREUM=

# Chainlink Price Feed Addresses
CHAINLINK_ETH_USD_FEED=0x5f4eC3Df9cbd43714FE2740f5E3616155c5b8419
CHAINLINK_MATIC_USD_FEED=0xAB594600376Ec9fD91F8e885dADF0CE036862dE0

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring
LOG_LEVEL=info
