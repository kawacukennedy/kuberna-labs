# Wallet Private Key (DO NOT COMMIT - use for deployments only)
PRIVATE_KEY=0x...

# RPC URLs for different networks
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v3/YOUR_ALCHEMY_KEY
POLYGON_RPC_URL=https://polygon-rpc.com
NEAR_RPC_URL=https://rpc.mainnet.near.org
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# API Keys
COINMARKETCAP_API_KEY=your_coinmarketcap_key
INFURA_API_KEY=your_infura_key
ALCHEMY_API_KEY=your_alchemy_key

# Gas Reporting
REPORT_GAS=true

# Backend Environment Variables
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/kuberna
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# NATS Configuration
NATS_URL=nats://localhost:4222

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email Configuration (SendGrid or AWS SES)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your_sendgrid_key
EMAIL_FROM=noreply@kuberna.africa

# TEE Provider Configuration
PHALA_ENDPOINT=https://api.phala.network
PHALA_API_KEY=your_phala_key
MARLIN_ENDPOINT=https://api.marlin.org
MARLIN_API_KEY=your_marlin_key

# zkTLS Provider Configuration
RECLAIM_API_KEY=your_reclaim_key
ZKPASS_API_KEY=your_zkpass_key

# Contract Addresses (update after deployment)
ESCROW_CONTRACT_ADDRESS_ETHEREUM=
ESCROW_CONTRACT_ADDRESS_POLYGON=
ESCROW_CONTRACT_ADDRESS_ARBITRUM=
INTENT_CONTRACT_ADDRESS_ETHEREUM=
PAYMENT_CONTRACT_ADDRESS_POLYGON=
CERTIFICATE_NFT_ADDRESS_ETHEREUM=
ATTESTATION_CONTRACT_ADDRESS_ETHEREUM=
REPUTATION_NFT_ADDRESS_ETHEREUM=
SUBSCRIPTION_CONTRACT_ADDRESS_ETHEREUM=
CROSSCHAIN_ROUTER_ADDRESS_ETHEREUM=

# Chainlink Price Feed Addresses
CHAINLINK_ETH_USD_FEED=0x5f4eC3Df9cbd43714FE2740f5E3616155c5b8419
CHAINLINK_MATIC_USD_FEED=0xAB594600376Ec9fD91F8e885dADF0CE036862dE0

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring
LOG_LEVEL=info
