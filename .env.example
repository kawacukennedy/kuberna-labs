RATE_LIMIT_MAX_REQUESTS=100

# Monitoring
LOG_LEVEL=info

# NPM Publishing Token (for CI auto-publish)
NPM_TOKEN=npm_your_token_here

# SilentVerify (Post-Quantum Agent PKI)
SILENTVERIFY_API_KEY=your_silentverify_api_key
SILENTVERIFY_BASE_URL=https://silentverify.up.railway.app

# Kite AI Integration (Agent Payments & Identity)
KITE_RPC_URL=https://rpc-testnet.gokite.ai
KITE_CHAIN_ID=2368
KITE_PASSPORT_API=https://agentpassport.ai/api
KITE_PAYMENT_TOKEN_ADDRESS=0x7aB6f3ed87C42eF0aDb67Ed95090f8bF5240149e
