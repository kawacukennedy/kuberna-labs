KITE_FACILITATOR_ADDRESS=0x12343e649e6b2b2b77649DFAb88f103c02F3C78b
KITE_SERVICE_WALLET=0xYourServiceWalletAddressOnKite
KITE_TESTNET_TOKEN=0x0fF5393387ad2f9f691FD6Fd28e07E3969e27e63

