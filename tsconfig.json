{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./"
  },
  "include": [
    "contracts/**/*",
    "scripts/**/*",
    "test/**/*",
    "frontend/**/*",
    "backend/**/*",
    "typechain-types/**/*"
  ],
  "exclude": ["node_modules", "dist"],
  "references": [{ "path": "./backend" }, { "path": "./sdk" }, { "path": "./frontend" }]
}
