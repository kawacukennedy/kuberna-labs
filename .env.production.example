# Kuberna Labs - Production Environment Variables
# ===============================================
# Copy and fill these values on Render Dashboard
# Settings -> Environment Variables
#
# For sensitive values, use "Secret" type on Render

# === REQUIRED ===

# Database URL (Render PostgreSQL or external like Neon/Supabase)
# Format: postgresql://user:password@host:port/database?sslmode=require
# Example: postgresql://kuberna:password@aws-0-us-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://user:password@host:5432/kuberna?sslmode=require

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=replace-with-random-64-char-hex-string

# === REQUIRED for Web3/Blockchain features ===

# RPC URL for your target blockchain (Base Sepolia, Polygon, etc.)
RPC_URL=https://sepolia.base.org

# Private key for backend blockchain operations (escrow, etc.)
# WARNING: Use a key with minimal funds, never your main wallet!
PRIVATE_KEY=0xyour-private-key-with-minimal-funds

# Smart contract addresses (deployed separately)
ESCROW_CONTRACT_ADDRESS=0x...
INTENT_CONTRACT_ADDRESS=0x...
AGENT_REGISTRY_CONTRACT_ADDRESS=0x...
CERTIFICATE_CONTRACT_ADDRESS=0x...
REPUTATION_CONTRACT_ADDRESS=0x...

# === REQUIRED for Frontend (must have NEXT_PUBLIC_ prefix) ===

# WalletConnect Project ID (get at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-project-id

# === OPTIONAL ===

# CORS origins (comma-separated, usually just your frontend URL)
ALLOWED_ORIGINS=https://your-app.onrender.com

# Frontend dist path (relative to backend/dist/)
FRONTEND_DIST_PATH=../frontend/out

# Stripe for payments
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI for AI features
OPENAI_API_KEY=sk-proj-...

# Redis URL (optional - rate limiting falls back to in-memory)
REDIS_URL=rediss://default:password@us-east-1.render.com:6379

# Email (SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
FROM_EMAIL=noreply@kuberna.africa
