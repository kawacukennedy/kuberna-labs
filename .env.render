# =============================================================================
# Kuberna Labs — Render Environment Variables Reference
# =============================================================================
# Copy these values into your Render dashboard Environment Variables section.
# Marked with ⚠️  = set via `sync: false` in render.yaml (prompted at deploy).
# Marked with 🔒 = sensitive (never commit real values).
# =============================================================================

# ----- Database (⚠️ Required) -----
# Transaction pooler (PgBouncer) for runtime
DATABASE_URL="postgresql://postgres.project-ref:password@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection for Prisma Migrate (⚠️ Must be set for migrations to work)
DIRECT_URL="postgresql://postgres.project-ref:password@db.project-ref.supabase.co:5432/postgres"

# ----- Server -----
NODE_ENV=production
PORT=10000
ALLOWED_ORIGINS=https://your-app.onrender.com

# ----- JWT (⚠️ Required) -----
JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=generate-with-openssl-rand-hex-32

# ----- Frontend (⚠️ Required for wallet connections) -----
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# ----- Blockchain (⚠️ Required for on-chain features) -----
RPC_URL=https://sepolia.base.org
PRIVATE_KEY=0x...

# ----- Smart Contract Addresses (Base Sepolia — 14 deployed) -----
ESCROW_CONTRACT_ADDRESS=0x360ec009ba6967F5f7C53a88FAD0452C6140493d
INTENT_CONTRACT_ADDRESS=0xB819ab0Bac2f22e8895C66fE3aDF23aa0a65145a
CERTIFICATE_NFT_CONTRACT_ADDRESS=0x5e42c329Ef517B495261f57054d5844EAabD3dbf
PAYMENT_CONTRACT_ADDRESS=0xFFe8A88E9E99938174B8a3C9EcA1c1462315395A
SUBSCRIPTION_CONTRACT_ADDRESS=0x9be7afE1793ad14F9026d7579cf7c2313184a7E0
REPUTATION_NFT_CONTRACT_ADDRESS=0xCCa946e3E2c2C307Cb2613d5C8107356ddD08c35
AGENT_REGISTRY_CONTRACT_ADDRESS=0x817fB0D00f033bb2982fF44855Fb6F8AE2D41324
COURSE_NFT_CONTRACT_ADDRESS=0x9b0D1d05A6EBafE6364648d9e7109E2C37e331BF
WORKSHOP_CONTRACT_ADDRESS=0x1Fa14FfB410EfA65b3aADBB9B65e2426A1fB0F66
DISPUTE_CONTRACT_ADDRESS=0x8bcc424C07afCf231046F58B15d3677b8E842023
TREASURY_CONTRACT_ADDRESS=0x5DA30BDE4A774dcccE6099717d6b41A6329fDe34
FEE_MANAGER_CONTRACT_ADDRESS=0xD27b4Dcec846bdfF2DB9D70B163bfb61A3090E2e
ATTESTATION_CONTRACT_ADDRESS=0xFB105A77806d365EdeCf45F677481043ec1D46F4
CROSSCHAIN_ROUTER_CONTRACT_ADDRESS=0xE2924838E5914cE099e5969aD63b0C4A4eeB8BAD
# RPC URL for the chain these contracts are on
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Alias: used by backend blockchain.ts
RPC_URL=https://sepolia.base.org

# ----- Optional: Redis -----
REDIS_URL=redis://...

# ----- Optional: Stripe -----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ----- Optional: OpenAI -----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ----- Optional: Email (SMTP) -----
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
FROM_EMAIL=noreply@kubernalabs.com

# ----- Optional: Frontend dist path -----
FRONTEND_DIST_PATH=../frontend/out
